NODE_ENV=development
PORT=4000
FASTLANE_JWT_SECRET=change-me-before-production
FASTLANE_JWT_ISSUER=fastlane-api
FASTLANE_JWT_AUDIENCE=fastlane-app
TRUST_PROXY=0
SERVE_WEB_DIST=0
ENFORCE_HTTPS=0
EXPO_PUBLIC_API_URL=http://localhost:4000
OAUTH_PUBLIC_BASE_URL=http://localhost:4000
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
OAUTH_ALLOWED_REDIRECT_PREFIXES=fastlane://,exp://,http://localhost,http://127.0.0.1,https://localhost,https://127.0.0.1
ALLOWED_WEB_ORIGINS=http://localhost:19006,http://127.0.0.1:19006
