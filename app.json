{
  "expo": {
    "name": "Fastlane",
    "slug": "fastlane-fasting-tracker",
    "version": "1.0.0",
    "scheme": "fastlane",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0b0907"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fastlane.tracker",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.fastlane.tracker",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0b0907"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#f59e0b",
          "defaultChannel": "default"
        }
      ],
      "expo-secure-store",
      "expo-document-picker"
    ]
  }
}
